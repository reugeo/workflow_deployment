# =============================================================
# .env.example - Required Environment Variables
# =============================================================
# HOW TO USE:
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your actual values (replace the placeholder text)
# 3. NEVER commit the .env file to Git (it's in .gitignore)
#
# For deployment, these values go into:
# - GitHub Secrets (for the CI/CD pipeline)
# - Render Environment Variables (for the running service)
# =============================================================

# --- n8n Authentication ---
# Username and password to access the n8n web interface
N8N_BASIC_AUTH_USER=your_n8n_username
N8N_BASIC_AUTH_PASSWORD=your_secure_password_here

# --- n8n Host Configuration ---
# The public URL where n8n will be accessible
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# --- Timezone ---
GENERIC_TIMEZONE=Asia/Kolkata

# --- Telegram Bot ---
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# --- Google Calendar OAuth2 ---
# Create these at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Google Gemini API ---
# Get this from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# --- OpenAI API Key (if used) ---
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# --- Docker Hub (for CI/CD only - set in GitHub Secrets) ---
# DOCKER_USERNAME=your_dockerhub_username
# DOCKER_PASSWORD=your_dockerhub_access_token

# --- Render (for CI/CD only - set in GitHub Secrets) ---
# RENDER_API_KEY=your_render_api_key
# RENDER_SERVICE_ID=your_render_service_id
